POSTGRES_PASSWORD=replace-with-a-long-random-password
API_KEY=replace-with-a-long-random-api-key
# Browser playback/upload uses this public key when API_KEY is enabled.
# Leave empty only if API_KEY is empty.
NEXT_PUBLIC_API_KEY=replace-with-a-long-random-api-key
MOCK_PROVIDERS=true
ASR_PROVIDER=faster_whisper
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=zh
WHISPER_BEAM_SIZE=5
HF_ENDPOINT=https://hf-mirror.com
CORS_ORIGINS=https://podcast.example.com

# 中国大陆网络默认使用 DaoCloud 的 Docker Hub 代理。
# 若已同步到 CODING，可替换为你的 CODING Docker Registry 地址。
DOCKER_MIRROR=m.daocloud.io/docker.io/library
NODE_IMAGE=m.daocloud.io/docker.io/library/node:22-alpine
PYTHON_IMAGE=m.daocloud.io/docker.io/library/python:3.12-slim
NPM_REGISTRY=https://registry.npmmirror.com
PIP_INDEX_URL=https://mirrors.cloud.tencent.com/pypi/simple
# APT_MIRROR=https://mirrors.cloud.tencent.com
APT_MIRROR=https://mirrors.tuna.tsinghua.edu.cn

COS_BUCKET=
COS_REGION=ap-shanghai
COS_SECRET_ID=
COS_SECRET_KEY=

TENCENT_ASR_APP_ID=
TENCENT_ASR_SECRET_ID=
TENCENT_ASR_SECRET_KEY=

DEEPSEEK_API_KEY=

HTTP_PORT=8080
HTTPS_PORT=8443
TLS_CERT_DIR=./nginx/certs
